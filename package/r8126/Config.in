comment "r8126 needs a Linux kernel to be built"
	depends on !BR2_LINUX_KERNEL

config BR2_PACKAGE_R8126
	bool "r8126"
	depends on BR2_LINUX_KERNEL
	depends on BR2_x86_64
	select BR2_LINUX_NEEDS_MODULES
	help
	  Realtek r8126 5 Gigabit Ethernet driver for RTL8126
	  series controllers. Replaces the in-kernel r8169 driver.

	  https://github.com/openwrt/rtl8126

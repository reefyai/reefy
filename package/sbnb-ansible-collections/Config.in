config BR2_PACKAGE_SBNB_ANSIBLE_COLLECTIONS
	bool "sbnb-ansible-collections"
	depends on BR2_PACKAGE_PYTHON_ANSIBLE_CORE
	help
	  Pre-install required Ansible collections for SBNB:
	  - community.general
	  - community.crypto
	  - community.docker
	  - ansible.posix
	  - geerlingguy.docker (role)

comment "sbnb-ansible-collections needs python-ansible-core"
	depends on !BR2_PACKAGE_PYTHON_ANSIBLE_CORE

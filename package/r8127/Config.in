comment "r8127 needs a Linux kernel to be built"
	depends on !BR2_LINUX_KERNEL

config BR2_PACKAGE_R8127
	bool "r8127"
	depends on BR2_LINUX_KERNEL
	depends on BR2_x86_64
	select BR2_LINUX_NEEDS_MODULES
	help
	  Realtek r8127 Ethernet driver for RTL8127 series controllers.
	  Replaces the in-kernel r8169 driver.

	  https://github.com/openwrt/rtl8127

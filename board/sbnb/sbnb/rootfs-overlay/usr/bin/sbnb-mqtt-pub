#!/usr/bin/env python3
"""
sbnb-mqtt-pub - Publish a message to MQTT using device credentials.

Usage:
    sbnb-mqtt-pub <topic_suffix> <json_payload>

Example:
    sbnb-mqtt-pub tunnel/status '{"status": "stopped", "reason": "idle_timeout"}'

The topic is automatically prefixed with: <prefix>/devices/<uuid>/
Config and certs are loaded from /mnt/sbnb-data/state/.
"""

import json
import os
import ssl
import sys
import time

try:
    import paho.mqtt.client as mqtt
except ImportError:
    print("ERROR: paho-mqtt not installed", file=sys.stderr)
    sys.exit(1)


def load_config():
    config = {}
    for path in ['/mnt/sbnb-data/state/mqtt.conf', '/mnt/sbnb/mqtt/mqtt.conf']:
        if os.path.exists(path):
            with open(path) as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith('#') and '=' in line:
                        k, v = line.split('=', 1)
                        config[k.strip()] = v.strip()
            break
    return config


def main():
    if len(sys.argv) < 3:
        print(f"Usage: {sys.argv[0]} <topic_suffix> <json_payload>", file=sys.stderr)
        sys.exit(1)

    topic_suffix = sys.argv[1]
    payload = sys.argv[2]

    # Validate JSON
    try:
        json.loads(payload)
    except json.JSONDecodeError as e:
        print(f"ERROR: Invalid JSON payload: {e}", file=sys.stderr)
        sys.exit(1)

    config = load_config()
    broker = config.get('MQTT_BROKER')
    if not broker:
        print("ERROR: No MQTT_BROKER in config", file=sys.stderr)
        sys.exit(1)

    port = int(config.get('MQTT_PORT', '443'))
    prefix = config.get('MQTT_TOPIC_PREFIX', 'sbnb')
    transport = config.get('MQTT_TRANSPORT', 'websockets')
    ca_cert = config.get('MQTT_CA_CERT', '/mnt/sbnb/mqtt/ca.crt')
    device_cert = config.get('MQTT_DEVICE_CERT', '/mnt/sbnb-data/state/device.crt')
    device_key = config.get('MQTT_DEVICE_KEY', '/mnt/sbnb-data/state/device.key')

    # Read device UUID
    uuid_file = '/mnt/sbnb-data/state/device-uuid'
    if not os.path.exists(uuid_file):
        print("ERROR: No device-uuid found (not provisioned?)", file=sys.stderr)
        sys.exit(1)
    with open(uuid_file) as f:
        device_uuid = f.read().strip()

    topic = f"{prefix}/devices/{device_uuid}/{topic_suffix}"

    # Create client and publish
    try:
        client = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2, transport=transport)
    except (AttributeError, TypeError):
        client = mqtt.Client(transport=transport)

    client.tls_set(
        ca_certs=ca_cert,
        certfile=device_cert,
        keyfile=device_key,
        cert_reqs=ssl.CERT_REQUIRED,
        tls_version=ssl.PROTOCOL_TLSv1_2,
    )

    if transport == 'websockets':
        ws_path = config.get('MQTT_WS_PATH', '/mqtt')
        client.ws_set_options(path=ws_path)

    client.connect(broker, port, 60)
    client.loop_start()
    info = client.publish(topic, payload, qos=1)
    info.wait_for_publish(timeout=10)
    client.disconnect()
    client.loop_stop()

    print(f"Published to {topic}")


if __name__ == '__main__':
    try:
        main()
    except Exception as e:
        print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)

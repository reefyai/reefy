#!/bin/sh
# Disable inherited set -e/pipefail — we handle errors explicitly
set +e +o pipefail 2>/dev/null
# sbnb-efi — Unified EFI boot entry and firmware management
#
# Commands:
#   sbnb-efi fix                    Verify/fix EFI entries + boot order
#   sbnb-efi update <efi-file> [-r] A/B firmware update with BootNext
#   sbnb-efi confirm                Commit current slot as default (swap BootOrder)
#   sbnb-efi status                 Show current slot info
#
# All commands are idempotent and self-healing:
# - Remove duplicate/stale EFI entries
# - Recreate missing entries with correct PARTUUIDs
# - Fix boot order (sbnb entries first)

set -e

SBNB_MNT="/mnt/sbnb"

# ── Helpers ──

die() { echo "Error: $1" >&2; exit 1; }

# Find the sbnb USB disk from what's mounted at /mnt/sbnb
# Sets: MOUNTED_DEV, DISK
find_disk() {
    MOUNTED_DEV=$(findmnt -n -o SOURCE "$SBNB_MNT" 2>/dev/null) || true
    [ -z "$MOUNTED_DEV" ] && return 1
    DISK="/dev/$(lsblk -no PKNAME "$MOUNTED_DEV" 2>/dev/null)"
    [ -b "$DISK" ] || return 1
}

# Resolve active/inactive slots
# Sets: ACTIVE_LABEL, INACTIVE_LABEL, INACTIVE_PART, INACTIVE_DEV, CURRENT_BOOTNUM
resolve_slots() {
    find_disk || die "$SBNB_MNT not mounted"

    CURRENT_BOOTNUM=$(efibootmgr 2>/dev/null | grep '^BootCurrent:' | awk '{print $2}')

    # Always resolve from what's mounted — BootCurrent can be a transient entry
    # that doesn't match the mounted ESP (e.g., after USB swap or UEFI quirks)
    if [ "$MOUNTED_DEV" = "${DISK}1" ]; then
        ACTIVE_LABEL="sbnb-a"
        INACTIVE_LABEL="sbnb-b"
        INACTIVE_PART=2
    else
        ACTIVE_LABEL="sbnb-b"
        INACTIVE_LABEL="sbnb-a"
        INACTIVE_PART=1
    fi

    INACTIVE_DEV="${DISK}${INACTIVE_PART}"
}

# Verify and fix all EFI boot entries. Idempotent.
# - Remove duplicates (UEFI auto-created entries pointing to our partitions)
# - Remove stale sbnb-a/sbnb-b entries (wrong PARTUUIDs from old USB)
# - Create missing sbnb-a/sbnb-b entries
# - Fix boot order (sbnb entries first)
fix_entries() {
    find_disk || die "$SBNB_MNT not mounted"

    GUID_A=$(blkid -s PARTUUID -o value "${DISK}1" 2>/dev/null)
    GUID_B=$(blkid -s PARTUUID -o value "${DISK}2" 2>/dev/null)

    mount -o remount,rw /sys/firmware/efi/efivars 2>/dev/null || true

    # Remove UEFI auto-created entries that point to our partitions but aren't sbnb-a/sbnb-b
    efibootmgr 2>/dev/null | grep '^Boot[0-9A-F]*\*' | while read -r line; do
        BOOTNUM=$(echo "$line" | sed 's/Boot\([0-9A-F]*\)\*.*/\1/')
        LABEL=$(echo "$line" | sed 's/Boot[0-9A-F]*\* //' | awk '{print $1}')
        [ "$LABEL" = "sbnb-a" ] && continue
        [ "$LABEL" = "sbnb-b" ] && continue
        ENTRY_DETAIL=$(efibootmgr -v 2>/dev/null | grep "^Boot${BOOTNUM}\*")
        if echo "$ENTRY_DETAIL" | grep -qi "${GUID_A}\|${GUID_B}" 2>/dev/null; then
            efibootmgr -b "$BOOTNUM" -B 2>/dev/null || true
            echo "[sbnb-efi] Removed duplicate entry: Boot${BOOTNUM} (${LABEL})"
        fi
    done

    # Remove stale sbnb-a/sbnb-b entries that don't point to current disk
    for SBNB_LABEL in sbnb-a sbnb-b; do
        SBNB_ENTRY=$(efibootmgr -v 2>/dev/null | grep "^Boot[0-9A-F]*\* ${SBNB_LABEL}[[:space:]]" || true)
        if [ -n "$SBNB_ENTRY" ]; then
            SBNB_NUM=$(echo "$SBNB_ENTRY" | sed 's/Boot\([0-9A-F]*\)\*.*/\1/')
            if ! echo "$SBNB_ENTRY" | grep -qi "${GUID_A}\|${GUID_B}" 2>/dev/null; then
                efibootmgr -b "$SBNB_NUM" -B 2>/dev/null || true
                echo "[sbnb-efi] Removed stale entry: Boot${SBNB_NUM} (${SBNB_LABEL})"
            fi
        fi
    done

    # Create missing entries
    if ! efibootmgr 2>/dev/null | grep -q "sbnb-a"; then
        efibootmgr -c -d "$DISK" -p 1 -L "sbnb-a" -l '\EFI\Boot\bootx64.efi' 2>/dev/null || true
        echo "[sbnb-efi] Created entry: sbnb-a"
    fi
    if ! efibootmgr 2>/dev/null | grep -q "sbnb-b"; then
        efibootmgr -c -d "$DISK" -p 2 -L "sbnb-b" -l '\EFI\Boot\bootx64.efi' 2>/dev/null || true
        echo "[sbnb-efi] Created entry: sbnb-b"
    fi

    # Fix boot order — sbnb entries must be first
    SBNB_A_NUM=$(efibootmgr 2>/dev/null | grep "sbnb-a" | sed 's/Boot\([0-9A-F]*\)\*.*/\1/')
    SBNB_B_NUM=$(efibootmgr 2>/dev/null | grep "sbnb-b" | sed 's/Boot\([0-9A-F]*\)\*.*/\1/')
    if [ -n "$SBNB_A_NUM" ] && [ -n "$SBNB_B_NUM" ]; then
        CURRENT_ORDER=$(efibootmgr 2>/dev/null | grep '^BootOrder:' | awk '{print $2}')
        FIRST=$(echo "$CURRENT_ORDER" | cut -d, -f1)
        if [ "$FIRST" != "$SBNB_A_NUM" ] && [ "$FIRST" != "$SBNB_B_NUM" ]; then
            efibootmgr -o "${SBNB_A_NUM},${SBNB_B_NUM}" 2>/dev/null || true
            echo "[sbnb-efi] Set BootOrder: ${SBNB_A_NUM},${SBNB_B_NUM}"
        fi
    fi

    mount -o remount,ro /sys/firmware/efi/efivars 2>/dev/null || true
}

# ── Commands ──

cmd_fix() {
    fix_entries
}

cmd_status() {
    resolve_slots
    SBNB_A_NUM=$(efibootmgr 2>/dev/null | grep "sbnb-a" | sed 's/Boot\([0-9A-F]*\)\*.*/\1/')
    SBNB_B_NUM=$(efibootmgr 2>/dev/null | grep "sbnb-b" | sed 's/Boot\([0-9A-F]*\)\*.*/\1/')
    echo "Active:   ${ACTIVE_LABEL} (Boot${CURRENT_BOOTNUM})"
    echo "Inactive: ${INACTIVE_LABEL} → ${INACTIVE_DEV}"
    echo "sbnb-a:   Boot${SBNB_A_NUM:-missing} → ${DISK}1"
    echo "sbnb-b:   Boot${SBNB_B_NUM:-missing} → ${DISK}2"
    efibootmgr 2>/dev/null | grep -E '^Boot(Current|Order|Next)'
}

cmd_confirm() {
    # Commit current boot slot as default by swapping BootOrder.
    # Called by sbnb-boot-confirm after health checks pass.
    CURRENT=$(efibootmgr 2>/dev/null | grep '^BootCurrent:' | awk '{print $2}')
    DEFAULT=$(efibootmgr 2>/dev/null | grep '^BootOrder:' | awk '{print $2}' | cut -d, -f1)

    if [ "$CURRENT" = "$DEFAULT" ]; then
        echo "[sbnb-efi] Already default slot, nothing to confirm"
        exit 0
    fi

    mount -o remount,rw /sys/firmware/efi/efivars 2>/dev/null || true
    efibootmgr -o "${CURRENT},${DEFAULT}" 2>/dev/null
    mount -o remount,ro /sys/firmware/efi/efivars 2>/dev/null || true

    echo "[sbnb-efi] Committed Boot${CURRENT} as default"
}

cmd_update() {
    EFI_FILE="$1"
    REBOOT=0
    [ "$2" = "-r" ] && REBOOT=1

    [ -z "$EFI_FILE" ] && die "Usage: sbnb-efi update <efi-file> [-r]"
    [ ! -f "$EFI_FILE" ] && die "File not found: $EFI_FILE"
    mountpoint -q "$SBNB_MNT" || die "$SBNB_MNT not mounted"

    # Acquire lock
    LOCK_FILE="/var/lock/sbnb-update.lock"
    exec 9>"$LOCK_FILE"
    flock -n 9 || die "Another update is already running"

    resolve_slots
    # Fix all EFI entries first (idempotent, self-healing)
    fix_entries

    # Re-read inactive boot number (may have been recreated by fix_entries)
    INACTIVE_BOOTNUM=$(efibootmgr 2>/dev/null | grep "^Boot[0-9A-F]*\* ${INACTIVE_LABEL}" | \
        sed 's/Boot\([0-9A-F]*\)\*.*/\1/')

    echo "A/B Update:"
    echo "  Active:   ${ACTIVE_LABEL} (Boot${CURRENT_BOOTNUM})"
    echo "  Inactive: ${INACTIVE_LABEL} (Boot${INACTIVE_BOOTNUM})"
    echo "  Target:   ${INACTIVE_DEV}"
    echo "  Source:    ${EFI_FILE}"

    # Format inactive ESP (fixes vfat corruption)
    echo "Formatting ${INACTIVE_DEV}..."
    mkfs.vfat -F 32 -n "${INACTIVE_LABEL}" "${INACTIVE_DEV}"

    # Write firmware to inactive slot
    INACTIVE_MNT=$(mktemp -d)
    mount "${INACTIVE_DEV}" "${INACTIVE_MNT}"
    cp -a "${SBNB_MNT}/mqtt" "${INACTIVE_MNT}/" 2>/dev/null || true
    mkdir -p "${INACTIVE_MNT}/EFI/Boot"
    echo "Copying EFI file..."
    cp "$EFI_FILE" "${INACTIVE_MNT}/EFI/Boot/bootx64.efi"
    sync
    umount "${INACTIVE_MNT}"
    rmdir "${INACTIVE_MNT}"

    # Set BootNext for one-shot try
    mount -o remount,rw /sys/firmware/efi/efivars 2>/dev/null || true
    efibootmgr -n "${INACTIVE_BOOTNUM}" 2>/dev/null

    if efibootmgr | grep -q "^BootNext:"; then
        echo "BootNext set to Boot${INACTIVE_BOOTNUM} — safe A/B update"
    else
        # BootNext not supported — fall back to overwriting active ESP too
        efibootmgr -N 2>/dev/null
        echo "BootNext not supported, overwriting active ESP too"
        mount -o remount,rw "$SBNB_MNT"
        cp "$EFI_FILE" "$SBNB_MNT/EFI/Boot/bootx64.efi"
        sync
        mount -o remount,ro "$SBNB_MNT"
    fi

    mount -o remount,ro /sys/firmware/efi/efivars 2>/dev/null || true

    echo "Update complete!"

    if [ "$REBOOT" -eq 1 ]; then
        echo "Rebooting in 3 seconds..."
        sleep 3
        reboot
    fi
}

# ── Main ──

case "${1:-}" in
    fix)     cmd_fix ;;
    status)  cmd_status ;;
    confirm) cmd_confirm ;;
    update)  shift; cmd_update "$@" ;;
    *)       echo "Usage: sbnb-efi {fix|update|confirm|status}"; exit 1 ;;
esac

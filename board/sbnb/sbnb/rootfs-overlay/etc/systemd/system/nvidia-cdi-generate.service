[Unit]
Description=Create NVIDIA device nodes and generate CDI specification
After=sbnb-storage.service systemd-modules-load.service
Wants=sbnb-storage.service

[Service]
Type=oneshot
Environment="LD_LIBRARY_PATH=/usr/lib"
ExecStart=/usr/bin/nvidia-cdi-setup.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target

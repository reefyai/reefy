#!/bin/sh
# reefy-boot-confirm: Confirm A/B boot slot after firmware update.
# No marker files — all state derived from EFI variables.
#
# If BootCurrent == BootOrder[0]: normal boot, nothing to do.
# If BootCurrent != BootOrder[0]: we booted via BootNext into new slot.
#   Wait for system health, then commit (make new slot the default).

CURRENT=$(efibootmgr 2>/dev/null | grep '^BootCurrent:' | awk '{print $2}')
DEFAULT=$(efibootmgr 2>/dev/null | grep '^BootOrder:' | awk '{print $2}' | cut -d, -f1)

# Normal boot — current slot is already the default
if [ "$CURRENT" = "$DEFAULT" ]; then
    exit 0
fi

echo "[boot-confirm] Booted from non-default slot Boot${CURRENT} (default: Boot${DEFAULT}), confirming..."

# Wait for critical services to be active (up to 300s).
# For each service: if it has failed, abort immediately (don't confirm the slot).
# If not yet active, keep waiting. Only confirm when all are active.
CRITICAL_SERVICES="reefy-storage reefy-mqtt"
WAITED=0
while [ $WAITED -lt 300 ]; do
    ALL_OK=true

    for svc in $CRITICAL_SERVICES; do
        if systemctl is-failed --quiet "$svc"; then
            echo "[boot-confirm] ABORT: $svc has failed, refusing to confirm boot slot"
            exit 1
        fi
        if ! systemctl is-active --quiet "$svc"; then
            ALL_OK=false
        fi
    done

    if [ "$ALL_OK" = true ]; then
        echo "[boot-confirm] All critical services active (waited ${WAITED}s)"
        break
    fi

    sleep 5
    WAITED=$((WAITED + 5))
done
if [ "$ALL_OK" != true ]; then
    echo "[boot-confirm] Critical services not active after 300s"
    exit 1
fi

# All checks passed — commit the new slot as default
reefy-efi confirm

# Stop the watchdog — boot is confirmed
systemctl stop reefy-boot-watchdog.service 2>/dev/null || true

#!/usr/bin/env python3
"""
reefy-backup — snapshot-based borg backup for app instances.

For each backup-enabled volume we LVM-thin-snapshot the volume's LV,
mount the snapshot read-only, run `borg create` from there, then
release the snapshot. Container is never paused. DB consistency
follows the standard crash-consistent guarantee modern engines
already handle (Postgres WAL, SQLite journal, InnoDB redo log).

Reads config from /mnt/reefy-data/state/backup/config.json.
Reports per-instance status via reefy-mqtt-pub.

Usage:
    reefy-backup                     # backup all instances
    reefy-backup <instance_uuid>     # backup single instance

Exit codes:
    0 — at least one instance succeeded
    2 — pool too full to snapshot safely (>=95%)
    3 — legacy storage (no thin pool); backups disabled until migration
"""

import hashlib
import json
import os
import subprocess
import sys
import time
from datetime import datetime, timezone

BACKUP_DIR = '/mnt/reefy-data/state/backup'
CONFIG_FILE = os.path.join(BACKUP_DIR, 'config.json')
SNAPSHOT_MNT_BASE = '/mnt/reefy-data/snapshots'

# LVM names — underscore separator avoids dm-mapper's `--` escape
# (see feedback_resource_naming_prefix.md).
STORAGE_VG = 'reefy'
STORAGE_POOL = 'reefy_pool'

POOL_FILL_WARN_PCT = 80
POOL_FILL_FAIL_PCT = 95


def publish_status(payload):
    """Report backup status via MQTT on the unified instance/status
    channel. Backend dispatches on action='backup' to update
    backup_configs.last_backup_status and fire the
    device.backup.completed SSE event."""
    payload = dict(payload)
    payload.setdefault('action', 'backup')
    try:
        subprocess.run(
            ['reefy-mqtt-pub', 'instance/status', json.dumps(payload)],
            capture_output=True, timeout=15
        )
    except Exception:
        pass


def run_borg(args, env, timeout=21600, retries=10, retry_delay=60, cwd=None):
    """Run a borg command with retries. Returns (success, stdout, stderr)."""
    FATAL_PATTERNS = (
        'passphrase', 'key', 'quota', 'no space left', 'permission denied',
        'not a valid repository', 'does not exist',
    )
    for attempt in range(retries):
        result = subprocess.run(
            ['borg'] + args,
            capture_output=True, text=True,
            timeout=timeout, env=env, cwd=cwd
        )
        if result.returncode == 0:
            return True, result.stdout, result.stderr
        err_lower = (result.stderr or '').lower()
        if any(p in err_lower for p in FATAL_PATTERNS):
            print(f"[backup] borg {args[0]} failed (fatal, no retry): {result.stderr.strip()[:200]}")
            return False, result.stdout, result.stderr
        if attempt < retries - 1:
            print(f"[backup] borg {args[0]} failed (attempt {attempt + 1}/{retries}), retrying in {retry_delay}s: {result.stderr.strip()[:100]}")
            time.sleep(retry_delay)
    return False, result.stdout, result.stderr


def thin_pool_present():
    """True if reefy_pool exists. Devices on legacy storage layout
    return False; backups disabled cleanly with exit 3."""
    return subprocess.run(
        ['lvs', f'{STORAGE_VG}/{STORAGE_POOL}'], capture_output=True
    ).returncode == 0


def pool_fill_pct():
    """Current data_percent of the thin pool (int 0-100), or None
    if the pool isn't present or the query fails."""
    r = subprocess.run(
        ['lvs', '--noheadings', '--nosuffix', '-o', 'data_percent',
         f'{STORAGE_VG}/{STORAGE_POOL}'],
        capture_output=True, text=True, timeout=5)
    if r.returncode != 0:
        return None
    try:
        return int(float(r.stdout.strip() or '0'))
    except ValueError:
        return None


def gc_orphan_snapshots():
    """Drop any reefy_snap_* LV left over from a crashed previous run.
    Each successful per-volume backup releases its own snapshot via the
    finally block, but SIGKILL / OOM / power loss between snapshot and
    finally would leave an orphan whose CoW deltas grow with origin
    writes until cleaned. This is the defense-in-depth GC at the start
    of every backup run."""
    r = subprocess.run(
        ['lvs', '--noheadings', '-o', 'lv_name',
         '--select', 'lv_name=~"^reefy_snap_"', STORAGE_VG],
        capture_output=True, text=True, timeout=10)
    if r.returncode != 0:
        return
    for line in r.stdout.split('\n'):
        snap = line.strip()
        if not snap:
            continue
        # Locate any mount point still referencing the snapshot LV
        # (we don't know the per-instance parent dir from the LV name
        # alone). Fall back to lvremove -- the LV has no kernel users
        # once unmounted.
        dev = f'/dev/{STORAGE_VG}/{snap}'
        m = subprocess.run(
            ['findmnt', '-n', '-o', 'TARGET', '--source', dev],
            capture_output=True, text=True, timeout=5)
        for snap_mnt in [t.strip() for t in m.stdout.split('\n') if t.strip()]:
            subprocess.run(['umount', snap_mnt], capture_output=True, timeout=10)
            parent = os.path.dirname(snap_mnt)
            try:
                os.rmdir(snap_mnt)
            except OSError:
                pass
            if parent and parent != SNAPSHOT_MNT_BASE:
                try:
                    os.rmdir(parent)
                except OSError:
                    pass
        subprocess.run(['lvremove', '-f', f'{STORAGE_VG}/{snap}'],
                       capture_output=True, timeout=15)
        print(f'[backup] GC: dropped orphan snapshot {snap}')


def volume_lv_name(path):
    """Mirror reefy-mqtt-reconciler._volume_lv_name (must produce the
    same name for the same path so the snapshot picks the right LV)."""
    h = hashlib.sha1(path.encode()).hexdigest()[:12]
    return f'reefy_backup_{h}'


def snapshot_volume(path, instance_uuid):
    """Snapshot the per-volume thin LV that backs `path`, mount the
    snapshot read-only at a path whose LEAF is the volume name (so
    borg captures it as e.g. `config/...` — same shape as legacy
    docker-pause archives, which means the restore code stays unchanged).

    Returns (snap_lv_name, snap_mount_path). Caller must
    release_snapshot() in a finally block — CoW grows as long as
    the snapshot exists."""
    lv_name = volume_lv_name(path)
    lv_path = f'/dev/{STORAGE_VG}/{lv_name}'
    if not os.path.exists(lv_path):
        raise RuntimeError(
            f'no per-volume LV for {path} (expected {lv_path}); '
            f'volume may not have been provisioned with backup support')

    # Snapshot LV name carries the timestamp so each backup run gets
    # a fresh name. Mount path uses {ts}/{instance_uuid}/{volname} so
    # borg cwd-ing to /snapshots/{ts}/{instance_uuid} can sweep all
    # volumes for the instance with relative paths matching the
    # legacy archive layout.
    vol_name = os.path.basename(path)
    ts = int(time.time())
    snap_name = f'reefy_snap_{lv_name[len("reefy_backup_"):]}_{ts}'
    snap_mnt = os.path.join(SNAPSHOT_MNT_BASE,
                             f'{ts}_{instance_uuid}', vol_name)

    # Snapshot of a thin LV lives in the same pool automatically;
    # `--thin` is not a valid flag combined with `--snapshot`.
    # `--setactivationskip n` overrides the default (which leaves
    # thin snapshots inactive — without this the /dev/<vg>/<snap>
    # block device doesn't exist for `mount` to find).
    r = subprocess.run(
        ['lvcreate', '--snapshot', '--setactivationskip', 'n',
         '--name', snap_name, f'{STORAGE_VG}/{lv_name}'],
        capture_output=True, text=True, timeout=15)
    if r.returncode != 0:
        raise RuntimeError(f'lvcreate snapshot failed: {r.stderr}')

    os.makedirs(snap_mnt, mode=0o755, exist_ok=True)
    r = subprocess.run(
        ['mount', '-o', 'ro', f'/dev/{STORAGE_VG}/{snap_name}', snap_mnt],
        capture_output=True, text=True, timeout=10)
    if r.returncode != 0:
        # Best-effort release before raising.
        subprocess.run(['lvremove', '-f', f'{STORAGE_VG}/{snap_name}'],
                       capture_output=True, timeout=15)
        raise RuntimeError(f'snapshot mount failed: {r.stderr}')

    return snap_name, snap_mnt


def release_snapshot(snap_name, snap_mnt):
    """Idempotent snapshot teardown - safe to call multiple times.
    Also rmdirs the per-instance parent dir if no sibling volumes
    remain (snap_mnt is /snapshots/{ts}_{iuuid}/{volname})."""
    if not snap_name:
        return
    subprocess.run(['umount', snap_mnt], capture_output=True, timeout=15)
    subprocess.run(['lvremove', '-f', f'{STORAGE_VG}/{snap_name}'],
                   capture_output=True, timeout=15)
    parent = os.path.dirname(snap_mnt)
    if os.path.isdir(snap_mnt):
        try:
            os.rmdir(snap_mnt)
        except OSError:
            pass
    if parent and parent != SNAPSHOT_MNT_BASE and os.path.isdir(parent):
        try:
            os.rmdir(parent)
        except OSError:
            pass


def backup_instance(inst, keep_last):
    """Backup one app instance via per-volume LVM snapshots. Returns
    True if every volume succeeded."""
    iuuid = inst['instance_uuid']
    archive_prefix = inst['archive_prefix']
    repo_path = inst['repo_path']
    passphrase = inst['passphrase']
    paths = inst['paths']

    key_path = os.path.join(BACKUP_DIR, iuuid, 'id_ed25519')
    if not os.path.exists(key_path):
        print(f"[backup] No SSH key for {iuuid}, skipping")
        return False

    env = os.environ.copy()
    env['BORG_PASSPHRASE'] = passphrase
    env['BORG_RSH'] = f'ssh -i {key_path} -o StrictHostKeyChecking=accept-new -o BatchMode=yes'
    env['BORG_RELOCATED_REPO_ACCESS_IS_OK'] = 'yes'
    env['BORG_LOCK_WAIT'] = '21600'

    archive_name = f"{archive_prefix}-{datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S')}"
    start_time = time.monotonic()

    # Repo init if needed.
    ok, _, stderr = run_borg(['info', repo_path], env)
    if not ok:
        if 'not a valid repository' in stderr or 'does not exist' in stderr or 'Repository' not in stderr:
            # First-attempt borg init for a fresh repo can hit
            # "Permission denied (publickey)" or "Connection closed by
            # remote host" if BorgBase's SSH server hasn't picked up
            # the just-registered key yet (server side does its own
            # pre-flight via get_repo, but the GraphQL ack and SSH
            # server propagation aren't atomic). Try a couple of times
            # with backoff before giving up - these errors are normally
            # in FATAL_PATTERNS so run_borg won't retry on its own.
            init_attempts = 3
            for attempt in range(1, init_attempts + 1):
                print(f"[backup] Initializing borg repo for {iuuid} "
                      f"(attempt {attempt}/{init_attempts})")
                ok, _, stderr = run_borg(
                    ['init', '--encryption=repokey-blake2', repo_path], env
                )
                if ok:
                    break
                err_lower = (stderr or '').lower()
                transient = (
                    'permission denied' in err_lower
                    or 'connection closed' in err_lower
                )
                if not transient or attempt == init_attempts:
                    print(f"[backup] Failed to init repo: {stderr}")
                    publish_status({
                        'instance_uuid': iuuid, 'status': 'error',
                        'message': 'repo init failed',
                    })
                    return False
                delay = 30 * attempt
                print(f"[backup] init transient ({stderr.strip()[:80]}); "
                      f"retrying in {delay}s")
                time.sleep(delay)
        else:
            print(f"[backup] Cannot access repo after retries: {stderr.strip()[:200]}")
            publish_status({
                'instance_uuid': iuuid, 'status': 'error',
                'message': 'repo access failed',
            })
            return False

    # Snapshot every volume, then borg-create from the snapshot mounts.
    # Held in a list so we can release in a single finally block.
    snapshots = []  # [(snap_name, snap_mnt, original_path)]
    try:
        try:
            for path in paths:
                snap_name, snap_mnt = snapshot_volume(path, iuuid)
                snapshots.append((snap_name, snap_mnt, path))
                print(f'[backup] Snapshot {snap_name} mounted at {snap_mnt}')
        except Exception as e:
            print(f'[backup] Snapshot setup failed for {iuuid}: {e}')
            publish_status({
                'instance_uuid': iuuid, 'status': 'error',
                'message': f'snapshot failed: {e}',
            })
            return False

        # All snapshots taken at near-the-same instant. snapshot_volume
        # mounts each at /snapshots/{ts}_{iuuid}/{volname} so the parent
        # dir is the per-instance container — borg cwd here, with
        # rel_paths = the volume names. Archive contents look like
        # `config/`, `data/`, ... — same shape as legacy archives so
        # the existing restore code path keeps working unchanged.
        snap_mounts = [s[1] for s in snapshots]
        common = os.path.dirname(snap_mounts[0])
        rel_paths = [os.path.basename(m) for m in snap_mounts]

        # Backup excludes (per-instance + global baseline) come from the
        # cloud-side backup config. Each entry is a borg `sh:` pattern
        # already prefixed with the volume name where appropriate, so we
        # pass them through unchanged. Owning this list cloud-side means
        # changing the baseline doesn't need a firmware rollout - devices
        # stay dumb consumers of whatever the backend ships. See
        # reefy-service APP-SPEC.md "Backup Excludes" for the rationale.
        exclude_args = []
        for pattern in inst.get('excludes', []) or []:
            exclude_args += ['--exclude', f'sh:{pattern}']

        print(f'[backup] Creating archive {archive_name} '
              f'(cwd={common}, vols={rel_paths}, '
              f'excludes={len(exclude_args)//2})')
        ok, stdout, stderr = run_borg(
            ['create', '--compression', 'zstd', '--json',
             *exclude_args,
             f'{repo_path}::{archive_name}'] + rel_paths,
            env, cwd=common
        )
        if not ok:
            print(f"[backup] borg create failed: {stderr}")
            publish_status({
                'instance_uuid': iuuid, 'status': 'error',
                'message': (stderr or '').strip()[:500] or 'borg create failed',
            })
            return False

        archive_size = None
        try:
            archive_size = json.loads(stdout).get('archive', {}).get('stats', {}).get('compressed_size')
        except (json.JSONDecodeError, AttributeError):
            pass

    finally:
        # Release every snapshot we took, regardless of borg outcome.
        # CoW deltas die here so the pool gets its space back.
        for snap_name, snap_mnt, _ in snapshots:
            release_snapshot(snap_name, snap_mnt)

    print(f"[backup] Archive created: {archive_name}")

    # Prune old archives, skipping pinned ones.
    pinned = set(inst.get('pinned_archives', []))
    if pinned:
        print(f"[backup] Pruning (keep-last={keep_last}, {len(pinned)} pinned)")
        ok, stdout, _ = run_borg(
            ['list', '--prefix', f'{archive_prefix}-', '--format', '{name}{NL}', repo_path],
            env, timeout=120
        )
        if ok and stdout.strip():
            all_archives = sorted(stdout.strip().split('\n'))
            unpinned = [a for a in all_archives if a not in pinned]
            to_delete = unpinned[:-keep_last] if len(unpinned) > keep_last else []
            for old_archive in to_delete:
                print(f"[backup] Deleting {old_archive}")
                run_borg(['delete', f'{repo_path}::{old_archive}'], env, timeout=120)
    else:
        print(f"[backup] Pruning (keep-last={keep_last})")
        run_borg(
            ['prune', '--prefix', f'{archive_prefix}-', '--keep-last', str(keep_last), repo_path],
            env, timeout=300
        )

    run_borg(['compact', repo_path], env, timeout=300)

    duration = int(time.monotonic() - start_time)
    timestamp = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S')
    print(f"[backup] Complete: {iuuid} ({duration}s, size={archive_size})")
    payload = {
        'instance_uuid': iuuid,
        'status': 'success',
        'archive': archive_name,
        'duration_s': duration,
        'timestamp': timestamp,
    }
    if archive_size is not None:
        payload['size_bytes'] = archive_size
    publish_status(payload)
    return True


def main():
    if not os.path.exists(CONFIG_FILE):
        print(f"[backup] No config file at {CONFIG_FILE}")
        return

    # Legacy-storage gate: pre-thin-pool installs can't snapshot.
    # Bail with a clear log so the dashboard can render
    # "Backups disabled — migrate to enable".
    if not thin_pool_present():
        print("[backup] LVM thin pool not present (legacy storage); "
              "backups disabled. Migrate to enable.")
        sys.exit(3)

    pct = pool_fill_pct()
    if pct is not None and pct >= POOL_FILL_FAIL_PCT:
        print(f"[backup] ERROR: thin pool at {pct}% — refusing to snapshot")
        sys.exit(2)
    if pct is not None and pct >= POOL_FILL_WARN_PCT:
        print(f"[backup] WARN: thin pool at {pct}%")

    # Drop any orphan snapshots from a previous crashed run.
    gc_orphan_snapshots()

    os.makedirs(SNAPSHOT_MNT_BASE, mode=0o755, exist_ok=True)

    with open(CONFIG_FILE) as f:
        config = json.load(f)

    keep_last = config.get('retention', {}).get('keep_last', 30)
    instances = config.get('instances', [])
    filter_uuid = sys.argv[1] if len(sys.argv) > 1 else None

    any_success = False
    for inst in instances:
        iuuid = inst.get('instance_uuid', '')
        if filter_uuid and iuuid != filter_uuid:
            continue
        try:
            if backup_instance(inst, keep_last):
                any_success = True
        except Exception as e:
            print(f"[backup] Instance {iuuid} failed: {e}")

    print("[backup] All backups complete")
    sys.exit(0 if any_success else 1)


if __name__ == '__main__':
    main()

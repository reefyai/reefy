#!/usr/bin/env python3
"""
MQTT terminal bridge — exposes a PTY shell over MQTT topics.

Allows remote terminal access for bootstrap (non-adopted) devices via
the dashboard. The browser sends keystrokes to terminal/input and
receives output from terminal/output.

Uses subscribe/unsubscribe gating: PTY is only spawned when a dashboard
user opens the terminal. Idle timeout kills the PTY after 30 minutes.
"""

import json
import os
import pty
import select
import signal
import ssl
import struct
import subprocess
import sys
import fcntl
import termios
import threading
import time

try:
    import paho.mqtt.client as mqtt
except ImportError:
    print("[terminal-bridge] ERROR: paho-mqtt not installed")
    sys.exit(1)

MQTT_CONF_PATH = '/mnt/reefy/mqtt/mqtt.conf'
STATE_DIR = '/mnt/reefy-data/state'
IDLE_TIMEOUT = 1800  # 30 min with no subscribers

_master_fd = None
_child_pid = None
_lock = threading.Lock()
_subscribers = 0
_last_activity = 0.0


def load_config():
    if not os.path.exists(MQTT_CONF_PATH):
        return None
    config = {}
    with open(MQTT_CONF_PATH) as f:
        for line in f:
            line = line.strip()
            if '=' in line and not line.startswith('#'):
                key, val = line.split('=', 1)
                config[key.strip()] = val.strip()
    return config


def get_device_uuid():
    for path in [os.path.join(STATE_DIR, 'device-uuid'), '/tmp/bootstrap-uuid']:
        if os.path.exists(path):
            with open(path) as f:
                uuid = f.read().strip()
                if uuid:
                    return uuid
    return None


def spawn_pty():
    """Spawn a bash shell with a PTY. Returns (master_fd, child_pid)."""
    master_fd, slave_fd = pty.openpty()
    pid = os.fork()
    if pid == 0:
        # Child
        os.close(master_fd)
        os.setsid()
        fcntl.ioctl(slave_fd, termios.TIOCSCTTY, 0)
        os.dup2(slave_fd, 0)
        os.dup2(slave_fd, 1)
        os.dup2(slave_fd, 2)
        if slave_fd > 2:
            os.close(slave_fd)
        os.environ['TERM'] = 'xterm-256color'
        os.execvp('tmux', ['tmux', 'new-session', '-A', '-s', 'host'])
    else:
        # Parent
        os.close(slave_fd)
        return master_fd, pid


def kill_pty():
    """Kill the PTY child process."""
    global _master_fd, _child_pid
    with _lock:
        if _child_pid:
            try:
                os.kill(_child_pid, signal.SIGTERM)
                os.waitpid(_child_pid, os.WNOHANG)
            except (OSError, ChildProcessError):
                pass
        if _master_fd:
            try:
                os.close(_master_fd)
            except OSError:
                pass
        _master_fd = None
        _child_pid = None


def ensure_pty():
    """Ensure PTY is running. Returns master_fd or None."""
    global _master_fd, _child_pid
    with _lock:
        if _master_fd is not None:
            # Check if child still alive
            try:
                pid, status = os.waitpid(_child_pid, os.WNOHANG)
                if pid != 0:
                    # Child exited
                    try:
                        os.close(_master_fd)
                    except OSError:
                        pass
                    _master_fd = None
                    _child_pid = None
            except ChildProcessError:
                try:
                    os.close(_master_fd)
                except OSError:
                    pass
                _master_fd = None
                _child_pid = None

        if _master_fd is None:
            _master_fd, _child_pid = spawn_pty()
            print(f"[terminal-bridge] Spawned PTY pid={_child_pid}")

        return _master_fd


def resize_pty(cols, rows):
    """Resize the PTY."""
    with _lock:
        if _master_fd is not None:
            winsize = struct.pack('HHHH', rows, cols, 0, 0)
            fcntl.ioctl(_master_fd, termios.TIOCSWINSZ, winsize)


def main():
    global _subscribers, _last_activity

    config = load_config()
    if not config:
        # Retry in bootstrap mode with bootstrap certs
        time.sleep(5)
        config = load_config()
        if not config:
            print("[terminal-bridge] No MQTT config found")
            sys.exit(1)

    uuid = get_device_uuid()
    if not uuid:
        print("[terminal-bridge] No device UUID found")
        sys.exit(1)

    public_id = config.get('MQTT_USER_ID', '')
    topic_prefix = f"reefy/{public_id}/devices/{uuid}"
    input_topic = f"{topic_prefix}/terminal/input"
    output_topic = f"{topic_prefix}/terminal/output"
    control_topic = f"{topic_prefix}/terminal/control"

    print(f"[terminal-bridge] UUID={uuid} topics={topic_prefix}/terminal/...")

    broker = config.get('MQTT_BROKER', 'mqtt.reefy.ai')
    port = int(config.get('MQTT_PORT', '443'))
    transport = config.get('MQTT_TRANSPORT', 'websockets')
    ws_path = config.get('MQTT_WS_PATH', '/mqtt')
    ca_cert = config.get('MQTT_CA_CERT', '/mnt/reefy/mqtt/ca.crt')

    # Use device certs if available, fall back to bootstrap certs
    client_cert = os.path.join(STATE_DIR, 'device.crt')
    client_key = os.path.join(STATE_DIR, 'device.key')
    if not os.path.exists(client_cert):
        client_cert = '/mnt/reefy/mqtt/bootstrap.crt'
        client_key = '/mnt/reefy/mqtt/bootstrap.key'

    client = mqtt.Client(
        callback_api_version=mqtt.CallbackAPIVersion.VERSION2,
        client_id=f'reefy-terminal-{os.getpid()}',
        transport=transport,
    )

    client.tls_set(
        ca_certs=ca_cert,
        certfile=client_cert,
        keyfile=client_key,
        cert_reqs=ssl.CERT_REQUIRED,
        tls_version=ssl.PROTOCOL_TLSv1_2,
    )

    if transport == 'websockets':
        client.ws_set_options(path=ws_path)

    client.reconnect_delay_set(min_delay=1, max_delay=60)

    def on_connect(cl, userdata, flags, rc, properties):
        print(f"[terminal-bridge] Connected to {broker}:{port}")
        cl.subscribe(input_topic, qos=0)
        cl.subscribe(control_topic, qos=1)

    def on_message(cl, userdata, msg):
        global _subscribers, _last_activity

        if msg.topic == control_topic:
            try:
                data = json.loads(msg.payload)
            except (json.JSONDecodeError, TypeError):
                return
            action = data.get('action')
            if action == 'subscribe':
                _subscribers += 1
                _last_activity = time.time()
                print(f"[terminal-bridge] Terminal opened (subscribers={_subscribers})")
                fd = ensure_pty()
                # Force tmux to redraw screen so new subscriber sees existing content
                if _child_pid:
                    os.kill(_child_pid, signal.SIGWINCH)
            elif action == 'unsubscribe':
                _subscribers = max(0, _subscribers - 1)
                print(f"[terminal-bridge] Terminal closed (subscribers={_subscribers})")
                if _subscribers == 0:
                    kill_pty()
            elif action == 'resize':
                cols = data.get('cols', 80)
                rows = data.get('rows', 24)
                resize_pty(cols, rows)
            return

        if msg.topic == input_topic:
            _last_activity = time.time()
            fd = ensure_pty()
            if fd is not None:
                try:
                    os.write(fd, msg.payload)
                except OSError:
                    kill_pty()

    def on_disconnect(cl, userdata, flags, rc, properties):
        print(f"[terminal-bridge] Disconnected (rc={rc})")

    client.on_connect = on_connect
    client.on_message = on_message
    client.on_disconnect = on_disconnect

    client.connect(broker, port, keepalive=60)
    client.loop_start()

    # Main loop: read PTY output and publish to MQTT
    try:
        while True:
            with _lock:
                fd = _master_fd

            if fd is not None:
                try:
                    r, _, _ = select.select([fd], [], [], 0.05)
                    if r:
                        data = os.read(fd, 4096)
                        if data:
                            client.publish(output_topic, data, qos=0)
                        else:
                            kill_pty()
                except OSError:
                    kill_pty()
            else:
                time.sleep(0.1)

            # Idle timeout
            if _subscribers > 0 and _last_activity > 0:
                if time.time() - _last_activity > IDLE_TIMEOUT:
                    print("[terminal-bridge] Idle timeout, killing PTY")
                    _subscribers = 0
                    kill_pty()
    except KeyboardInterrupt:
        pass
    finally:
        kill_pty()
        client.loop_stop()
        client.disconnect()


if __name__ == '__main__':
    main()

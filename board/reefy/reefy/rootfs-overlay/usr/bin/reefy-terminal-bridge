#!/usr/bin/env python3
"""
MQTT terminal bridge — exposes PTY shells over MQTT topics.

Supports multiple sessions: one host terminal and per-app container terminals.

Topic structure:
  reefy/{public_id}/devices/{uuid}/terminal/{session_id}/input
  reefy/{public_id}/devices/{uuid}/terminal/{session_id}/output
  reefy/{public_id}/devices/{uuid}/terminal/{session_id}/control

session_id = "host" for the host shell, or an app instance UUID for
container terminals. The control subscribe message may include a
"container" field to exec into a specific docker container.

Uses subscribe/unsubscribe gating: PTY is only spawned when a dashboard
user opens the terminal. Idle timeout kills the PTY after 30 minutes.
"""

import json
import os
import pty
import select
import signal
import ssl
import struct
import subprocess
import sys
import fcntl
import termios
import threading
import time

try:
    import paho.mqtt.client as mqtt
except ImportError:
    print("[terminal-bridge] ERROR: paho-mqtt not installed")
    sys.exit(1)

MQTT_CONF_PATH = '/mnt/reefy/mqtt/mqtt.conf'
STATE_DIR = '/mnt/reefy-data/state'
IDLE_TIMEOUT = 1800  # 30 min with no subscribers

# Multi-session state: session_id -> {master_fd, child_pid, subscribers, last_activity}
_sessions = {}
_lock = threading.Lock()


def load_config():
    if not os.path.exists(MQTT_CONF_PATH):
        return None
    config = {}
    with open(MQTT_CONF_PATH) as f:
        for line in f:
            line = line.strip()
            if '=' in line and not line.startswith('#'):
                key, val = line.split('=', 1)
                config[key.strip()] = val.strip()
    return config


def get_device_uuid():
    for path in [os.path.join(STATE_DIR, 'device-uuid'), '/tmp/bootstrap-uuid']:
        if os.path.exists(path):
            with open(path) as f:
                uuid = f.read().strip()
                if uuid:
                    return uuid
    return None


def _get_container_shell(container):
    """Read APP_SHELL env var from the container (set by desired-state
    from app.json "shell" field). Returns the shell command or None."""
    try:
        result = subprocess.run(
            ['docker', 'inspect', container, '--format',
             '{{range .Config.Env}}{{println .}}{{end}}'],
            capture_output=True, text=True, timeout=5)
        for line in result.stdout.splitlines():
            if line.startswith('APP_SHELL='):
                return line[len('APP_SHELL='):]
    except Exception:
        pass
    return None


def spawn_pty(session_id, container=None, name=None):
    """Spawn a PTY shell. If container specified, docker exec into it.
    Reads APP_SHELL from the container's env for custom shell commands
    (e.g. venv activation). Falls back to bash -> sh if unset."""
    # For app containers: write a wrapper script so tmux's default-command
    # can reuse it for new panes (all panes exec into the same container).
    wrapper_path = None
    if container:
        wrapper_path = f'/tmp/reefy-term-{session_id}'
        display = name or container
        shell = _get_container_shell(container)
        if shell:
            shell_cmd = shell
        else:
            shell_cmd = 'if command -v bash >/dev/null; then exec bash --norc --noprofile; else exec sh; fi'
        with open(wrapper_path, 'w') as f:
            f.write("#!/bin/sh\n"
                    f"exec docker exec -e REEFY_APP='{display}' -it {container} sh -c '\n"
                    '    export "PS1=$(whoami 2>/dev/null || echo user)@${REEFY_APP}# "\n'
                    f"    {shell_cmd}\n"
                    "'\n")
        os.chmod(wrapper_path, 0o755)

    master_fd, slave_fd = pty.openpty()
    pid = os.fork()
    if pid == 0:
        # Child
        os.close(master_fd)
        os.setsid()
        fcntl.ioctl(slave_fd, termios.TIOCSCTTY, 0)
        os.dup2(slave_fd, 0)
        os.dup2(slave_fd, 1)
        os.dup2(slave_fd, 2)
        if slave_fd > 2:
            os.close(slave_fd)
        os.environ['TERM'] = 'xterm-256color'
        if wrapper_path:
            # App container: create/attach tmux session with docker exec wrapper.
            # - Dead sessions (docker exec exited) are killed and recreated
            # - Alive sessions are reused (multiple subscribers share)
            # - default-command ensures new panes also exec into the container
            os.execvp('sh', ['sh', '-c',
                f'tmux has-session -t {session_id} 2>/dev/null && '
                f'  tmux list-panes -t {session_id} -F "#{{pane_dead}}" 2>/dev/null | grep -q 1 && '
                f'  tmux kill-session -t {session_id} 2>/dev/null; '
                f'tmux has-session -t {session_id} 2>/dev/null || '
                f'  tmux new-session -d -s {session_id} {wrapper_path}; '
                f'tmux set-option -t {session_id} default-command {wrapper_path} 2>/dev/null; '
                f'exec tmux attach-session -t {session_id}'])
        else:
            # Host terminal
            os.execvp('tmux', ['tmux', 'new-session', '-A', '-s', 'host'])
    else:
        # Parent
        os.close(slave_fd)
        return master_fd, pid


def get_session(session_id):
    """Get or create session dict."""
    if session_id not in _sessions:
        _sessions[session_id] = {
            'master_fd': None,
            'child_pid': None,
            'subscribers': 0,
            'last_activity': 0.0,
            'container': None,
            'name': None,
        }
    return _sessions[session_id]


def kill_session(session_id):
    """Kill a PTY session."""
    with _lock:
        s = _sessions.get(session_id)
        if not s:
            return
        if s['child_pid']:
            try:
                os.kill(s['child_pid'], signal.SIGTERM)
                os.waitpid(s['child_pid'], os.WNOHANG)
            except (OSError, ChildProcessError):
                pass
        if s['master_fd']:
            try:
                os.close(s['master_fd'])
            except OSError:
                pass
        s['master_fd'] = None
        s['child_pid'] = None


def ensure_session_pty(session_id):
    """Ensure PTY is running for session. Returns master_fd or None."""
    with _lock:
        s = get_session(session_id)

        if s['master_fd'] is not None:
            # Check if child still alive
            try:
                pid, status = os.waitpid(s['child_pid'], os.WNOHANG)
                if pid != 0:
                    try:
                        os.close(s['master_fd'])
                    except OSError:
                        pass
                    s['master_fd'] = None
                    s['child_pid'] = None
            except ChildProcessError:
                try:
                    os.close(s['master_fd'])
                except OSError:
                    pass
                s['master_fd'] = None
                s['child_pid'] = None

        if s['master_fd'] is None:
            s['master_fd'], s['child_pid'] = spawn_pty(
                session_id, container=s['container'], name=s['name'])
            target = s['container'] or 'host'
            print(f"[terminal-bridge] Spawned PTY session={session_id} target={target} pid={s['child_pid']}")

        return s['master_fd']


def resize_session(session_id, cols, rows):
    """Resize the PTY for a session."""
    with _lock:
        s = _sessions.get(session_id)
        if s and s['master_fd'] is not None:
            winsize = struct.pack('HHHH', rows, cols, 0, 0)
            fcntl.ioctl(s['master_fd'], termios.TIOCSWINSZ, winsize)


def main():
    config = load_config()
    if not config:
        time.sleep(5)
        config = load_config()
        if not config:
            print("[terminal-bridge] No MQTT config found")
            sys.exit(1)

    uuid = get_device_uuid()
    if not uuid:
        print("[terminal-bridge] No device UUID found")
        sys.exit(1)

    public_id = config.get('MQTT_USER_ID', '')
    topic_base = f"reefy/{public_id}/devices/{uuid}/terminal"

    print(f"[terminal-bridge] UUID={uuid} topics={topic_base}/+/...")

    broker = config.get('MQTT_BROKER', 'mqtt.reefy.ai')
    port = int(config.get('MQTT_PORT', '443'))
    transport = config.get('MQTT_TRANSPORT', 'websockets')
    ws_path = config.get('MQTT_WS_PATH', '/mqtt')
    ca_cert = config.get('MQTT_CA_CERT', '/mnt/reefy/mqtt/ca.crt')

    client_cert = os.path.join(STATE_DIR, 'device.crt')
    client_key = os.path.join(STATE_DIR, 'device.key')
    if not os.path.exists(client_cert):
        client_cert = '/mnt/reefy/mqtt/bootstrap.crt'
        client_key = '/mnt/reefy/mqtt/bootstrap.key'

    client = mqtt.Client(
        callback_api_version=mqtt.CallbackAPIVersion.VERSION2,
        client_id=f'reefy-terminal-{os.getpid()}',
        transport=transport,
    )

    client.tls_set(
        ca_certs=ca_cert,
        certfile=client_cert,
        keyfile=client_key,
        cert_reqs=ssl.CERT_REQUIRED,
        tls_version=ssl.PROTOCOL_TLSv1_2,
    )

    if transport == 'websockets':
        client.ws_set_options(path=ws_path)

    client.reconnect_delay_set(min_delay=1, max_delay=60)

    # Subscriptions: (topic, qos)
    subscriptions = [
        (f"{topic_base}/+/input", 0),
        (f"{topic_base}/+/control", 1),
    ]
    # Track SUBACK confirmation: paho can report on_connect after a network
    # blip, but the broker can drop the resulting SUBSCRIBE silently. Without
    # this, the bridge thinks it is subscribed while the broker has no subs
    # for it and drops all input messages. Fix: track MIDs from subscribe(),
    # mark confirmed on on_subscribe, watchdog re-subscribes if missing.
    sub_state = {'confirmed': False, 'pending_mids': set()}

    def do_subscribe(cl):
        sub_state['confirmed'] = False
        sub_state['pending_mids'].clear()
        for topic, qos in subscriptions:
            result, mid = cl.subscribe(topic, qos)
            if result == 0:
                sub_state['pending_mids'].add(mid)
            else:
                print(f"[terminal-bridge] subscribe({topic}) error rc={result}")
        print(f"[terminal-bridge] Subscribe sent (mids={sub_state['pending_mids']})")

    def on_connect(cl, userdata, flags, rc, properties):
        print(f"[terminal-bridge] Connected to {broker}:{port}")
        do_subscribe(cl)

    def on_subscribe(cl, userdata, mid, reason_codes, properties):
        sub_state['pending_mids'].discard(mid)
        if not sub_state['pending_mids']:
            sub_state['confirmed'] = True
            print(f"[terminal-bridge] All {len(subscriptions)} subscriptions confirmed")

    def on_message(cl, userdata, msg):
        # Parse session_id and message type from topic
        # topic = "reefy/.../terminal/{session_id}/{input|control}"
        parts = msg.topic.rsplit('/', 2)
        if len(parts) < 3:
            return
        session_id = parts[-2]
        msg_type = parts[-1]

        if msg_type == 'control':
            try:
                data = json.loads(msg.payload)
            except (json.JSONDecodeError, TypeError):
                return
            action = data.get('action')
            if action == 'subscribe':
                with _lock:
                    s = get_session(session_id)
                    s['subscribers'] += 1
                    s['last_activity'] = time.time()
                    # Store container/name from first subscribe (for spawn)
                    if data.get('container'):
                        s['container'] = data['container']
                    if data.get('name'):
                        s['name'] = data['name']
                target = data.get('container', 'host')
                print(f"[terminal-bridge] Terminal opened session={session_id} target={target} (subscribers={s['subscribers']})")
                ensure_session_pty(session_id)
                # Apply initial size from subscriber (avoids tmux rendering at default 80x24)
                cols = data.get('cols', 0)
                rows = data.get('rows', 0)
                if cols and rows:
                    resize_session(session_id, cols, rows)
                # Force tmux redraw so new subscriber sees existing content
                with _lock:
                    s = _sessions.get(session_id)
                    if s and s['child_pid']:
                        os.kill(s['child_pid'], signal.SIGWINCH)
            elif action == 'unsubscribe':
                with _lock:
                    s = get_session(session_id)
                    s['subscribers'] = max(0, s['subscribers'] - 1)
                    subs = s['subscribers']
                print(f"[terminal-bridge] Terminal closed session={session_id} (subscribers={subs})")
                if subs == 0:
                    kill_session(session_id)
            elif action == 'resize':
                cols = data.get('cols', 80)
                rows = data.get('rows', 24)
                resize_session(session_id, cols, rows)
            return

        if msg_type == 'input':
            with _lock:
                s = _sessions.get(session_id)
                if s:
                    s['last_activity'] = time.time()
            fd = ensure_session_pty(session_id)
            if fd is not None:
                try:
                    os.write(fd, msg.payload)
                except OSError:
                    kill_session(session_id)

    def on_disconnect(cl, userdata, flags, rc, properties):
        print(f"[terminal-bridge] Disconnected (rc={rc})")

    client.on_connect = on_connect
    client.on_message = on_message
    client.on_disconnect = on_disconnect
    client.on_subscribe = on_subscribe

    client.connect(broker, port, keepalive=30)
    client.loop_start()

    # Watchdog: if subscriptions not confirmed within 30s of connect,
    # re-issue subscribe. Catches silent broker SUBACK drops.
    def subscription_watchdog():
        while True:
            time.sleep(30)
            if client.is_connected() and not sub_state['confirmed']:
                print("[terminal-bridge] Subscriptions not confirmed - re-subscribing")
                do_subscribe(client)

    threading.Thread(target=subscription_watchdog, daemon=True,
                     name='term-sub-watchdog').start()

    # Main loop: read PTY output from all sessions and publish to MQTT
    try:
        while True:
            fd_to_session = {}
            with _lock:
                for sid, s in _sessions.items():
                    if s['master_fd'] is not None:
                        fd_to_session[s['master_fd']] = sid

            if fd_to_session:
                try:
                    readable, _, _ = select.select(list(fd_to_session.keys()), [], [], 0.05)
                    for fd in readable:
                        sid = fd_to_session[fd]
                        try:
                            data = os.read(fd, 4096)
                            if data:
                                output_topic = f"{topic_base}/{sid}/output"
                                client.publish(output_topic, data, qos=0)
                            else:
                                kill_session(sid)
                        except OSError:
                            kill_session(sid)
                except (ValueError, OSError):
                    # fd closed between lock release and select
                    pass
            else:
                time.sleep(0.1)

            # Idle timeout per session
            now = time.time()
            with _lock:
                expired = []
                for sid, s in _sessions.items():
                    if s['subscribers'] > 0 and s['last_activity'] > 0:
                        if now - s['last_activity'] > IDLE_TIMEOUT:
                            expired.append(sid)
            for sid in expired:
                print(f"[terminal-bridge] Idle timeout session={sid}")
                with _lock:
                    s = _sessions.get(sid)
                    if s:
                        s['subscribers'] = 0
                kill_session(sid)

    except KeyboardInterrupt:
        pass
    finally:
        for sid in list(_sessions.keys()):
            kill_session(sid)
        client.loop_stop()
        client.disconnect()


if __name__ == '__main__':
    main()

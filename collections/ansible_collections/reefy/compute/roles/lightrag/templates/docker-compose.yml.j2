services:
  lightrag:
    image: {{ reefy_lightrag_image }}
    network_mode: host
    environment:
      PORT: {{ reefy_lightrag_port }}
      LLM_BINDING_HOST: http://127.0.0.1:{{ reefy_lightrag_ollama_port }}
      EMBEDDING_BINDING_HOST: http://127.0.0.1:{{ reefy_lightrag_ollama_port }}
    volumes:
      - {{ reefy_lightrag_data_path }}:/app/data
